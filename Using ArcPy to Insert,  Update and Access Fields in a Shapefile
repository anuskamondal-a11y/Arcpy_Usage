arcpy.env.workspace=r"C:\Users\Prog. for Ent GIS\Data"

#creating an attribute
field1="routename"
fieldlength=70
field2="length"
fieldprecision=8
feature="Pune_route.shp"
# arcpy.management.AddField(feature, field1, "TEXT", fieldlength)
# arcpy.management.AddField(feature, field2, "Double", fieldprecision)
print("Fields added")


#updating the data
#where_clause condition should be given in '', or else it won't work
updatenewcursor=arcpy.da.UpdateCursor(feature, "routename",
                                      where_clause="routename='PunetoMahabaleshwar' AND length=1000")
#for loop is used to get each row and use it
for row in updatenewcursor:
    row[0]="punetoSataraRiver"
    updatenewcursor.updateRow(row)
print("The Routename is updated.")

#Data addition in Multiple columns
updatenewcursor=arcpy.da.UpdateCursor(feature, ["routename","length"],
                                      where_clause="routename='PunetoMahabaleshwar' OR length=1000")
#for loop is used to access each row and use it to update
for row in updatenewcursor:
    row[0]="punetoSataraRiver"
    row[1]="700"
    updatenewcursor.updateRow(row)
print("The Routename and lenght is updated.")
